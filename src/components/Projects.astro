---
import ProjectCard from './ProjectCard.astro';

// TUS DATOS DE PROYECTOS (Esto queda igual)
const misProyectos = [
  {
    title: "Armador de Equipos",
    description: "Genera equipos de fútbol aleatorios desde una lista de jugadores, con opción de ajustar manualmente intercambiando integrantes y posibilidad de remezclarlos instantáneamente para equilibrar la distribución y mantener partidas justas. ",
    imgSrc: "/img/proyecto11.png",
    tags: ["JavaScript", "HTML5", "CSS3", "Bootstrap 5"],
    demoUrl: "https://tomasgallas.github.io/armador-equipos/",
    repoUrl: "https://github.com/tomasgallas/armador-equipos"
  },
  {
    title: "LabsLIA",
    description: "Sistema de gestión de laboratorios informáticos para instituciones educativas, desarrollado con Jakarta EE. Permite la administración de recursos, programación de reservas, control de inventario y gestión de usuarios según roles.",
    imgSrc: "/img/labslia.png",
    tags: ["Java","MySQL","GlassFish","Jakarta EE"],
    repoUrl:"https://github.com/tomasgallas/LabsLIA-java"
  },
  {
    title: "Gestion Universitaria",
    description: "Sistema que permite la gestión de diversas entidades académicas como Materias, Facultades, Carreras, Alumnos, Exámenes y Docentes. Incluye funcionalidades CRUD para cada entidad y reportes específicos generados mediante consultas JPQL.",
    imgSrc: "/img/alumnos.png",
    tags: ["Java","MySQL","GlassFish","Jakarta EE"],
    repoUrl:"https://github.com/tomasgallas/AppAlumnosBackEndIII"
  },
  {
    title: "Biblioteca",
    description: "Plataforma web que centraliza libros y autores. Con login para admin, bibliotecario y alumno, permite gestionar usuarios, controlar inventario y mostrar menús y permisos según el rol, todo desde una interfaz única.",
    imgSrc: "/img/biblioteca.png",
    tags: ["Node.js", "React", ".NET Core", "SQLite"],
    repoUrl: "https://github.com/tomasgallas/bibliotecaBackEnd"
  },
  {
    title: "Landing Page para Negocio",
    description: "El proyecto consiste en el desarrollo de una landing page y catálogo digital para NTN Tintas y Toners , un negocio de venta de insumos informáticos y servicios de recarga y reparación.",
    imgSrc: "/img/ntn.png",
    tags: ["Astro","GitHub Pages","HTML5","CSS3","JavaScript"],
    demoUrl:"https://tintasytonersntn-coder.github.io/",
    repoUrl:"https://github.com/tintasytonersntn-coder/tintasytonersntn-coder.github.io"
  },
];
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section id="proyectos">
  <h2 class="fade-in-up">Proyectos Destacados</h2>
  
  <div class="swiper mySwiper">
    <div class="swiper-wrapper">
      {misProyectos.map((proyecto, index) => (
        <div class="swiper-slide fade-in-up" style={`--delay: ${0.2 * (index + 1)}s;`}>
          <ProjectCard {...proyecto} />
        </div>
      ))}
    </div>
    
    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-pagination"></div>
  </div>
</section>

<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script is:inline>
  // Definimos la función de inicio
  const iniciarSwiper = () => {
    new Swiper('.mySwiper', {
      // Nota: Ya no necesitamos importar "modules" aquí porque el bundle trae todo
      loop: true,
      slidesPerView: 1,
      spaceBetween: 30,
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      breakpoints: {
        768: {
          slidesPerView: 2,
        },
        1024: {
          slidesPerView: 3,
        },
      },
    });
  };

  // Ejecutamos inmediatamente
  iniciarSwiper();

  // Aseguramos compatibilidad si navegas entre páginas en Astro
  document.addEventListener('astro:page-load', iniciarSwiper);
</script>

<style>
  /* Estilos de seguridad para que el contenedor no tenga ancho cero */
  .swiper {
    width: 100%;
    padding-bottom: 50px;
  }
  
  .swiper-slide {
    height: auto;
    display: flex;
    justify-content: center;
  }
</style>